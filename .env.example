# Copy this file to .env and fill in the values. Do NOT commit .env.

# Required — your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Port the FastAPI server listens on
PORT=5050

# Sampling temperature for the realtime model
TEMPERATURE=0.8

# Optional — path to a PDF whose text is loaded as grounding context.
# If the file is missing, the assistant simply runs without document context.
PDF_PATH=document.pdf
